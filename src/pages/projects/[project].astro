---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { marked } from 'marked';


//该页是动态路由的项目详情页

// 生成所有项目页面
export async function getStaticPaths() {
  const files = import.meta.glob('../../project-descriptions/*/descripcion.md');

  return Object.keys(files).map(path => {
    const folder = path.split('/').slice(-2, -1)[0];
    return { params: { project: folder } };
  });
}
// 当前项目路由
const { project } = Astro.params;


// 读取 Markdown（原始文本）
const enFiles = import.meta.glob(
  '../../project-descriptions/*/descripcion.en.md',
  { query: '?raw', import: 'default' }
);

const esFiles = import.meta.glob(
  '../../project-descriptions/*/descripcion.md',
  { query: '?raw', import: 'default' }
);

// 读取 Markdown
const enRaw = await enFiles[`../../project-descriptions/${project}/descripcion.en.md`]() as string;
const esRaw = await esFiles[`../../project-descriptions/${project}/descripcion.md`]() as string;

// 🔥 修复图片路径
function fixPaths(content: string): string {
  return content.replaceAll(
    './picture/',
    `../../project-descriptions/${project}/picture/`
  );
}
//md文件中正确图片地址wxample： <img src="./picture/heyfood1.png" class="rounded-xl shadow-lg" />

const enContent = fixPaths(enRaw);
const esContent = fixPaths(esRaw);

const enHtml = marked(enContent);
const esHtml = marked(esContent);
---

<Layout title={`${project} | Sihang Wu`}>
  <Header />

  <main class="min-h-screen px-4 sm:px-6 md:px-6">
    <article class="prose dark:prose-invert max-w-3xl mx-auto pt-24 pb-16 fade-in">

      <!-- 返回按钮 -->
      <a href="/projects"
        class="text-sm font-medium text-gray-500 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white transition-colors mb-8 inline-block">
        ← Back to Projects
      </a>

      <!-- 英文渲染 -->
      <div class="locale-en prose max-w-none dark:prose-invert">
        <div set:html={enHtml} />
      </div>

      <!-- 中文渲染 -->
      <div class="locale-es prose max-w-none dark:prose-invert">
        <div set:html={esHtml} />
      </div>

    </article>
  </main>

  <Footer />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      document.querySelector('.fade-in')?.classList.add('visible');
    });
  </script>
</Layout>