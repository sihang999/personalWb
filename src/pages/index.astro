---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import heroPhoto from '../assets/sihang1.jpg';
import cvFile from '../assets/CV/CV_Sihang_Wu.pdf';

const translations = {
  greeting: { 
    en: "Hello, I'm", 
    es: "Hola, soy" 
  },
  name: { 
    en: "Sihang Wu", 
    es: "Sihang Wu" 
  },
  description: { 
    en: "Technologist in Information Systems and Full Stack Developer with more than 2 years of experience, specialized in creating modern, scalable and user-centered solutions.", 
    es: "Tecnólogo en Sistemas de información y Desarrollador Full Stack con más de 2 años de experiencia, especializado en crear soluciones modernas, escalables y centradas en el usuario." 
  },
  availability: {
    en: "Open to work",
    es: "Disponible para trabajar"
  },
  viewProjects: { 
    en: "View Projects", 
    es: "Ver Proyectos" 
  },
  getInTouch: { 
    en: "Get in Touch", 
    es: "Contactar" 
  },
	roleTitle: {
		en: "Full Stack Developer",
		es: "Full Stack Developer"
	},
	downloadCv: {
		en: "Download CV",
		es: "Descargar CV"
	},
  about: { 
    en: "About Me", 
    es: "Sobre mí" 
  },
  aboutDesc: {
    es: "Soy Desarrollador Full Stack con experiencia en la creación de aplicaciones web completas, desde el diseño de la arquitectura hasta la implementación y despliegue. Trabajo integrando APIs, bases de datos y servicios modernos, con foco en rendimiento, mantenibilidad y experiencia de usuario. Me adapto bien a equipos colaborativos, sigo buenas prácticas de desarrollo y busco entregar soluciones estables que aporten valor real al negocio. Estoy interesado en oportunidades remotas o híbridas donde pueda seguir creciendo profesionalmente y contribuir a proyectos bien estructurados.",
    en: "I am a Full Stack Developer with experience building end-to-end web applications, from architecture design to implementation and deployment. I work integrating APIs, databases, and modern services, with a focus on performance, maintainability, and user experience. I adapt well to collaborative teams, follow development best practices, and aim to deliver stable solutions that bring real business value. I am interested in remote or hybrid opportunities where I can continue growing professionally and contribute to well-structured projects."
  },
  tech: { 
    en: "Tech Stack", 
    es: "Tecnologías" 
  }
};

const educationTranslations = {
  subtitle: { en: 'My Journey', es: 'Mi Trayectoria' },
  title: { en: 'Education', es: 'Educación' },
  description: { 
    en: 'A timeline of my academic background.',
    es: 'Una línea de tiempo de mi formación académica.'
  }
};

const education = [
  {
    year: '10/2023 - 04/2026',
    yearES: '10/2023 - 04/2026',
    title: 'M.Sc. Communication and Electronics Engineering',
    titleES: 'Máster en Ingeniería de Comunicaciones y Electrónica',
    school: 'Technical University of Munich',
    description: 'Focused on analog/mixed-signal IC design, PLL/DLL systems, and circuit modeling.',
    descriptionES: 'Enfoque en diseño de circuitos analógicos/mixtos, sistemas PLL/DLL y modelado de circuitos.'
  },
  {
    year: '2020 - 2023',
    yearES: '2020 - 2023',
    title: 'B.Sc. Electrical and Electronic Engineering',
    titleES: 'Grado en Ingeniería Eléctrica y Electrónica',
    school: 'University of Duisburg-Essen',
    description: 'Part of a dual-degree program with Zhengzhou University, focused on electronics and communication systems.',
    descriptionES: 'Parte de un programa de doble titulación con la Universidad de Zhengzhou, enfocado en electrónica y sistemas de comunicación.'
  },
  {
    year: '2018 - 2020',
    yearES: '2018 - 2020',
    title: 'B.Sc. Electrical and Information Engineering',
    titleES: 'Grado en Ingeniería Eléctrica y Electrónica',
    school: 'Zhengzhou University',
    description: 'Dual-degree program in collaboration with University of Duisburg-Essen, covering electronics, signal processing, and communication systems.',
    descriptionES: 'Programa de doble titulación en colaboración con la Universidad de Duisburg-Essen, enfocado en electrónica, procesamiento de señales y sistemas de comunicación.'
  }
];



const esDescriptions = import.meta.glob('../project-descriptions/*/descripcion.md', { query: '?raw', import: 'default' });
const enDescriptions = import.meta.glob('../project-descriptions/*/descripcion.en.md', { query: '?raw', import: 'default' });

const projectFolders = Object.keys(esDescriptions).map(path => {
  const parts = path.split('/');
  return parts[parts.length - 2];
});

const projects = await Promise.all(projectFolders.map(async (folder) => {
  const esPath = `../project-descriptions/${folder}/descripcion.md`;
  const enPath = `../project-descriptions/${folder}/descripcion.en.md`;
  
  const esContent = await esDescriptions[esPath]() as string;
  const enContent = await enDescriptions[enPath]() as string;
  
  const esTitle = esContent.split('\n')[0].replace(/### |# /g, '');
  const enTitle = enContent.split('\n')[0].replace(/### |# /g, '');

  return {
    slug: folder,
    name: esTitle,
    enName: enTitle
  };
}));

const featuredProjects = projects.slice(0, 2);




const workTranslations = {
  title: { en: 'Work Experience', es: 'Experiencia Laboral' },
  description: { 
    en: 'My professional and research experience.',
    es: 'Mi experiencia profesional y de investigación.'
  }
};

const work = [
  {
    year: '08/2025 - 04/2026',
    yearES: '08/2025 - 04/2026',
    title: 'Embedded Systems & Bionic Skin Research Assistant',
    titleES: 'Asistente de Investigación en Sistemas Embebidos y Piel Biónica',
    company: 'Technical University of Munich | Institute of Cognitive Systems',
    description: 'Developed embedded hardware systems based on hexagonal MCU modules. Responsible for FPC integration and system testing under Linux environments, ensuring system stability and functionality.',
    descriptionES: 'Desarrollé sistemas embebidos basados en módulos MCU hexagonales, integrando hardware FPC y realizando pruebas en entorno Linux.'
  },
  {
    year: '02/2025 - 08/2025',
    yearES: '02/2025 - 08/2025',
    title: 'DLL Circuit & Layout Design Research Intern',
    titleES: 'Practicante en Diseño de Circuitos y Layout DLL',
    company: 'Technical University of Munich | Institute of Circuit Design',
    description: 'Designed a full DLL system in 22nm FDSOI, including sampling signal generation, sampling circuits, and VCDL modules. Completed layout design with over 35 metal layers while considering parasitic effects and reliability.',
    descriptionES: 'Diseñé un sistema DLL completo en tecnología FDSOI de 22nm, incluyendo generación de señales de muestreo, circuitos y módulos VCDL.'
  },
  {
    year: '02/2023 - 08/2023',
    yearES: '02/2023 - 08/2023',
    title: 'Software Development Support Intern',
    titleES: 'Ingeniero en Prácticas de Desarrollo de Software',
    company: 'Huawei (Germany Headquarters) | European Service Operations Center',
    description: 'Developed internal tools and automated workflows using Python and HTML, including batch data processing and user behavior tracking. Improved efficiency by over 300%, significantly reducing manual workload. Gained experience in version control (Git) and containerized deployment (Docker).',
    descriptionES: 'Desarrollé herramientas internas y automatización de procesos utilizando Python y HTML, incluyendo procesamiento masivo de datos y seguimiento del comportamiento de usuarios. Mejoré la eficiencia en más del 300%.'
  }
];


---

<Layout title={`Home | Sihang Wu`}>
	<Header />
	
	<main class="min-h-screen px-4 sm:px-6 md:px-6">
		<section class="max-w-3xl mx-auto min-h-[70vh] flex flex-col justify-center pt-30 sm:pt-30 pb-10 sm:pb-10 fade-in">
			<div class="flex flex-col items-center gap-6 sm:gap-8 text-center">
				<div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
					<div class="w-24 h-24 sm:w-28 sm:h-28 md:w-32 md:h-32 rounded-full bg-gray-100 dark:bg-gray-800 border-2 border-gray-300 dark:border-gray-600 flex items-center justify-center overflow-hidden animated-border always-visible flex-shrink-0 shadow-lg dark:shadow-white/20">
						<img src={heroPhoto.src} alt="Sihang Wu" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
						<span class="text-2xl sm:text-3xl md:text-4xl text-gray-500 dark:text-gray-400 hidden">📷</span>
					</div>
					<div class="animated-border always-visible px-3 sm:px-4 py-2 rounded-full border border-gray-300 dark:border-gray-600 h-fit">
						<p class="text-xs sm:text-sm font-medium text-gray-900 dark:text-white whitespace-nowrap" data-en={translations.availability.en} data-es={translations.availability.es}>{translations.availability.en}</p>
					</div>
				</div>
				<div>
					<p class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-400 mb-2" data-en={translations.greeting.en} data-es={translations.greeting.es}>{translations.greeting.en}</p>
					<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6 px-2 sm:px-0" data-en={translations.name.en} data-es={translations.name.es}>
						{translations.name.en}
					</h1>

					<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 max-w-lg mx-auto mb-4 sm:mb-6 px-2 sm:px-0">
						<span class="font-semibold text-gray-900 dark:text-white"
							data-en="Analog/Mixed-Signal IC Design Engineer"
							data-es="Ingeniero de Diseño IC Analógico/Mixto">
							Analog/Mixed-Signal IC Design Engineer
						</span>

						<br class="hidden sm:block" />

						<span
							data-en="Focused on PLL/DLL design, system modeling, and high-performance circuit implementation."
							data-es="Especializado en diseño PLL/DLL, modelado de sistemas y circuitos de alto rendimiento.">
							Focused on PLL/DLL design, system modeling, and high-performance circuit implementation.
						</span>
					</p>

					<div class="flex flex-wrap gap-2 sm:gap-3 justify-center px-2 sm:px-0">
						<a href={cvFile} download="CV_Sihang_Wu.pdf"
							class="cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-medium rounded-full hover:animated-bg transition-all"
							data-en={translations.downloadCv.en}
							data-es={translations.downloadCv.es}>
							{translations.downloadCv.en}
						</a>
						<a href="/contact" class="animated-border cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white font-medium rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" data-en={translations.getInTouch.en} data-es={translations.getInTouch.es}>
							{translations.getInTouch.en}
						</a>
					</div>
					<div class="hidden mt-8 sm:mt-10 flex justify-center px-2 sm:px-0">
						<article class="cv-download-card group" aria-label="Download CV card">
							<div class="cv-download-card-inner">
								<div class="text-gray-50 text-left">
									<span class="cv-initials">Jr</span>
									<p class="cv-role" data-en={translations.roleTitle.en} data-es={translations.roleTitle.es}>{translations.roleTitle.en}</p>
								</div>
								<a href={cvFile} download="CV_Javier_Castillo.pdf" class="cv-download-button" data-en={translations.downloadCv.en} data-es={translations.downloadCv.es}>
									<span>{translations.downloadCv.en}</span>
									<svg class="w-5 h-5 fill-current" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
										<path d="M22.1,77.9a4,4,0,0,1,4-4H73.9a4,4,0,0,1,0,8H26.1A4,4,0,0,1,22.1,77.9ZM35.2,47.2a4,4,0,0,1,5.7,0L46,52.3V22.1a4,4,0,1,1,8,0V52.3l5.1-5.1a4,4,0,0,1,5.7,0,4,4,0,0,1,0,5.6l-12,12a3.9,3.9,0,0,1-5.6,0l-12-12A4,4,0,0,1,35.2,47.2Z" fill-rule="evenodd"></path>
									</svg>
								</a>
							</div>

							<svg class="cv-avatar cv-avatar-main" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" aria-hidden="true"><path d="M50.4 51C40.5 49.1 40 46 40 44v-1.2a18.9 18.9 0 0 0 5.7-8.8h.1c3 0 3.8-6.3 3.8-7.3s.1-4.7-3-4.7C53 4 30 0 22.3 6c-5.4 0-5.9 8-3.9 16-3.1 0-3 3.8-3 4.7s.7 7.3 3.8 7.3c1 3.6 2.3 6.9 4.7 9v1.2c0 2 .5 5-9.5 6.8S2 62 2 62h60a14.6 14.6 0 0 0-11.6-11z"/></svg>
							<svg class="cv-avatar cv-avatar-accent" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" aria-hidden="true"><path d="M50.4 51C40.5 49.1 40 46 40 44v-1.2a18.9 18.9 0 0 0 5.7-8.8h.1c3 0 3.8-6.3 3.8-7.3s.1-4.7-3-4.7C53 4 30 0 22.3 6c-5.4 0-5.9 8-3.9 16-3.1 0-3 3.8-3 4.7s.7 7.3 3.8 7.3c1 3.6 2.3 6.9 4.7 9v1.2c0 2 .5 5-9.5 6.8S2 62 2 62h60a14.6 14.6 0 0 0-11.6-11z"/></svg>
						</article>
					</div>
				</div>
			</div>
		</section>


		<section class="max-w-3xl mx-auto py-8 sm:py-10 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">

			<!-- 标题 -->
			<div class="max-w-2xl mb-8 sm:mb-10">
				<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white"
					data-en={educationTranslations.title.en}
					data-es={educationTranslations.title.es}>
					{educationTranslations.title.en}
				</h2>

				<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mt-2 sm:mt-3"
				data-en={educationTranslations.description.en}
				data-es={educationTranslations.description.es}>
				{educationTranslations.description.en}
				</p>
			</div>

			<!-- Timeline -->
			<div class="space-y-8 sm:space-y-12">

				{
				education.map((edu) => (
					<div class="relative pl-6 sm:pl-8 border-l-2 border-gray-200 dark:border-gray-700 group cursor-pointer hover:scale-105 transition-all">

					<div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-400 dark:bg-gray-500 group-hover:scale-125 transition-transform"></div>

					<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2">
						<h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-white"
							data-en={edu.title}
							data-es={edu.titleES}>
							{edu.title}
						</h3>

						<span class="text-xs sm:text-sm text-gray-500 dark:text-gray-400"
							data-en={edu.year}
							data-es={edu.yearES}>
							{edu.year}
						</span>
					</div>

					<p class="text-sm sm:text-lg text-gray-600 dark:text-gray-400 font-medium mb-2">
						{edu.school}
					</p>

					<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400"
						data-en={edu.description}
						data-es={edu.descriptionES}>
						{edu.description}
					</p>
					</div>
				))
				}

			</div>
		</section>


<section class="max-w-3xl mx-auto py-8 sm:py-10 border-t border-gray-200 dark:border-gray-700 parallax-section ade-in px-2 sm:px-0">

  <!-- 标题 -->
  <div class="max-w-2xl mb-6 sm:mb-8">
	<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white"
        data-en="Projects"
        data-es="Proyectos">
        Projects
    </h2>

    <p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mt-2 sm:mt-3"
       data-en="Selected projects showcasing my technical skills."
