---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import heroPhoto from '../assets/sihang1.jpg';
import cvFile from '../assets/CV/CV_Sihang_Wu.pdf';

const translations = {
  greeting: { 
    en: "Hello, I'm", 
    es: "你好，我是" 
  },
  name: { 
    en: "Sihang Wu", 
    es: "吴思航" 
  },
  heroTitle: {
    en: "Analog/Mixed-Signal IC Design Engineer",
    es: "模拟/混合信号IC设计工程师"
  },
  heroSubtitle: {
    en: "Focused on PLL/DLL design, system modeling, and high-performance circuit implementation.",
    es: "专注于PLL/DLL设计、系统建模以及高性能集成电路实现"
  },
  availability: {
    en: "Open to work",
    es: "开放求职中"
  },
  getInTouch: { 
    en: "Get in Touch", 
    es: "联系我" 
  },
  downloadCv: {
    en: "Download CV",
    es: "下载简历"
  },
  about: { 
    en: "About Me", 
    es: "关于我" 
  },
  tech: { 
    en: "Tech Stack", 
    es: "技能" 
  },

  projects: {
    title: {
      en: "Projects",
      es: "项目"
    },
    description: {
      en: "Selected projects showcasing my technical skills.",
      es: ""
    },
    viewProject: {
      en: "View Project",
      es: "查看项目"
    },
    viewAll: {
      en: "View all projects →",
      es: "查看所有项目 →"
    }
  }
};

const educationTranslations = {
  title: { en: 'Education', es: '教育背景' },
  description: { 
    en: 'A timeline of my academic background.',
    es: ''
  }
};

const education = [
  {
    year: '10/2023 - 04/2026',
    yearES: '10/2023 - 04/2026',
    title: 'M.Sc. Communication and Electronics Engineering',
    titleES: '通信与电子工程硕士',
    school: 'Technical University of Munich',
    schoolES: '慕尼黑工业大学',
    description: 'Focused on analog/mixed-signal IC design, PLL/DLL systems, and circuit modeling.',
    descriptionES: '专注于模拟/混合信号集成电路设计、PLL/DLL系统以及电路建模'
  },
  {
    year: '2020 - 2023',
    yearES: '2020 - 2023',
    title: 'B.Sc. Electrical and Electronic Engineering',
    titleES: '电气与电子工程学士',
    school: 'University of Duisburg-Essen',
    schoolES: '杜伊斯堡-埃森大学',
    description: 'Part of a dual-degree program with Zhengzhou University, focused on electronics and communication systems.',
    descriptionES: '与郑州大学合作的双学位项目，专注于电子与电气系统'
  },
  {
    year: '2018 - 2020',
    yearES: '2018 - 2020',
    title: 'B.Sc. Electrical and Information Engineering',
    titleES: '电气与信息工程学士',
    school: 'Zhengzhou University',
    schoolES: '郑州大学',
    description: 'Dual-degree program in collaboration with University of Duisburg-Essen, covering electronics, signal processing, and communication systems.',
    descriptionES: '与杜伊斯堡-埃森大学合作的双学位项目，涵盖电子、电信号处理及信息系统'
  }
];


const esDescriptions = import.meta.glob('../project-descriptions/*/description.md', { query: '?raw', import: 'default' });
const enDescriptions = import.meta.glob('../project-descriptions/*/description.en.md', { query: '?raw', import: 'default' });

const projectFolders = Object.keys(esDescriptions).map(path => {
  const parts = path.split('/');
  return parts[parts.length - 2];
});

const projects = await Promise.all(projectFolders.map(async (folder) => {
  const esPath = `../project-descriptions/${folder}/description.md`;
  const enPath = `../project-descriptions/${folder}/description.en.md`;
  
  const esContent = await esDescriptions[esPath]() as string;
  const enContent = await enDescriptions[enPath]() as string;
  
  const esTitle = esContent.split('\n')[0].replace(/### |# /g, '');
  const enTitle = enContent.split('\n')[0].replace(/### |# /g, '');

  return {
    slug: folder,
    name: esTitle,
    enName: enTitle
  };
}));

const featuredProjects = projects.slice(0, 2);



const workTranslations = {
  title: { en: 'Work Experience', es: '工作经历' },
  description: { 
    en: 'My professional and research experience.',
    es: ''
  }
};

const work = [
  {
    year: '07/2025 - 04/2026',
    yearES: '07/2025 - 04/2026',
    title: 'Embedded Systems & Bionic Skin Research Assistant',
    titleES: '嵌入式系统与仿生皮肤科研助理',
    company: 'Technical University of Munich | Institute of Cognitive Systems',
    companyES: '慕尼黑工业大学 | 认知系统研究所',
    description: 'Developed embedded hardware systems based on hexagonal MCU modules. Responsible for FPC integration and system testing under Linux environments, ensuring system stability and functionality.',
    descriptionES: '基于六边形MCU模块开发嵌入式硬件系统，负责FPC集成及Linux环境下系统测试，确保系统稳定性与功能完整性'
  },
  {
    year: '02/2025 - 07/2025',
    yearES: '02/2025 - 07/2025',
    title: 'DLL Circuit & Layout Design Research Intern',
    titleES: 'DLL电路与版图设计科研实习生',
    company: 'Technical University of Munich | Institute of Circuit Design',
    companyES: '慕尼黑工业大学 | 电路设计研究所',
    description: 'Designed a full DLL system in 22nm FDSOI, including sampling signal generation, sampling circuits, and VCDL modules. Completed layout design with over 35 metal layers while considering parasitic effects and reliability.',
    descriptionES: '在22nm FDSOI工艺下设计完整DLL系统，包括采样信号生成、采样电路及VCDL模块；完成超过35层金属的版图设计，并考虑寄生效应与可靠性问题'
  },
  {
    year: '02/2023 - 08/2023',
    yearES: '02/2023 - 08/2023',
    title: 'Software Development Support Intern',
    titleES: '软件开发支持实习生',
    company: 'Huawei (Germany Headquarters) | European Service Operations Center',
    companyES: '华为（德国总部）| 欧洲服务运营中心',
    description: 'Developed internal tools and automated workflows using Python and HTML, including batch data processing and user behavior tracking. Improved efficiency by over 300%, significantly reducing manual workload. Gained experience in version control (Git) and containerized deployment (Docker).',
    descriptionES: '使用Python与HTML开发内部工具并实现流程自动化，包括批量数据处理与用户行为分析；将工作效率提升300%以上，大幅减少人工操作；熟悉Git版本控制及Docker容器化部署'
  }
];


---

<Layout title={`Home | Sihang Wu`}>
	<Header />
	
	<main class="min-h-screen px-4 sm:px-6 md:px-6">
	
		<div id="password-modal"
			class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center z-50">
			<div class="bg-white dark:bg-gray-900 p-6 rounded-xl shadow-xl w-80">

				<h2 class="text-lg font-bold mb-4 text-center">
				Secret Access 🔐
				</h2>

				<input id="password-input"
					type="password"
					placeholder="Enter password"
					class="w-full border px-3 py-2 rounded mb-4 dark:bg-gray-800" />
				<button onclick="checkPassword()"
						class="w-full bg-black text-white py-2 rounded hover:opacity-80">
				Enter
				</button>
			</div>
		</div>

		<section class="max-w-3xl mx-auto min-h-[70vh] flex flex-col justify-center pt-30 sm:pt-30 pb-10 sm:pb-10 fade-in">
			<div class="flex flex-col items-center gap-6 sm:gap-8 text-center">
				<div class="flex flex-col sm:flex-row items-center justify-center gap-3 sm:gap-4">
					<div class="w-24 h-24 sm:w-28 sm:h-28 md:w-32 md:h-32 rounded-full bg-gray-100 dark:bg-gray-800 border-2 border-gray-300 dark:border-gray-600 flex items-center justify-center overflow-hidden animated-border always-visible flex-shrink-0 shadow-lg dark:shadow-white/20">
						<img src={heroPhoto.src} alt="Sihang Wu" class="w-full h-full object-cover" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
						<span class="text-2xl sm:text-3xl md:text-4xl text-gray-500 dark:text-gray-400 hidden">📷</span>
					</div>
					<!-- 是否求职 -->
					<div class="hidden animated-border always-visible px-3 sm:px-4 py-2 rounded-full border border-gray-300 dark:border-gray-600 h-fit">
						<p class="text-xs sm:text-sm font-medium text-gray-900 dark:text-white whitespace-nowrap" data-en={translations.availability.en} data-es={translations.availability.es}>{translations.availability.en}</p>
					</div>
				</div>
				<div>
					<p class="text-xs sm:text-sm font-medium text-gray-600 dark:text-gray-400 mb-2" data-en={translations.greeting.en} data-es={translations.greeting.es}>{translations.greeting.en}</p>
					
					<h1 id="secret-trigger"
						class="cursor-pointer text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6 px-2 sm:px-0"
						data-en={translations.name.en}
						data-es={translations.name.es}>
						{translations.name.en}
					</h1>
					
					<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 max-w-lg mx-auto mb-4 sm:mb-6 px-2 sm:px-0">
						<span class="font-semibold text-gray-900 dark:text-white"
								data-en={translations.heroTitle.en}
								data-es={translations.heroTitle.es}>
								{translations.heroTitle.en}
						</span>

						<br class="hidden sm:block" />

						<span
							data-en={translations.heroSubtitle.en}
							data-es={translations.heroSubtitle.es}>
							{translations.heroSubtitle.en}
						</span>
					</p>

					<div class="flex flex-wrap gap-2 sm:gap-3 justify-center px-2 sm:px-0">
						<a href={cvFile} download="CV_Sihang_Wu.pdf"
							class="cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-medium rounded-full hover:animated-bg transition-all"
							data-en={translations.downloadCv.en}
							data-es={translations.downloadCv.es}>
							{translations.downloadCv.en}
						</a>
						<a href="/contact" class="animated-border cursor-pointer px-4 sm:px-5 py-2 sm:py-2.5 text-sm sm:text-base border border-gray-300 dark:border-gray-600 text-gray-900 dark:text-white font-medium rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors" data-en={translations.getInTouch.en} data-es={translations.getInTouch.es}>
							{translations.getInTouch.en}
						</a>
					</div>
				</div>
			</div>
		</section>


		<section class="max-w-3xl mx-auto py-8 sm:py-10 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">

			<!-- 标题 -->
			<div class="max-w-2xl mb-8 sm:mb-10">
				<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white"
					data-en={educationTranslations.title.en}
					data-es={educationTranslations.title.es}>
					{educationTranslations.title.en}
				</h2>

				<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mt-2 sm:mt-3"
				data-en={educationTranslations.description.en}
				data-es={educationTranslations.description.es}>
				{educationTranslations.description.en}
				</p>
			</div>

			<!-- Timeline -->
			<div class="space-y-8 sm:space-y-12">

				{
				education.map((edu) => (
					<div class="relative pl-6 sm:pl-8 border-l-2 border-gray-200 dark:border-gray-700 group cursor-pointer hover:scale-105 transition-all">

					<div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-400 dark:bg-gray-500 group-hover:scale-125 transition-transform"></div>

					<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2">
						<h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-white"
							data-en={edu.title}
							data-es={edu.titleES}>
							{edu.title}
						</h3>

						<span class="text-xs sm:text-sm text-gray-500 dark:text-gray-400"
							data-en={edu.year}
							data-es={edu.yearES}>
							{edu.year}
						</span>
					</div>

					<!-- 学校 -->
					<p class="text-sm sm:text-lg text-gray-600 dark:text-gray-400 font-medium mb-2"
						data-en={edu.school}
						data-es={edu.schoolES}>
						{edu.school}
					</p>

					<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400"
						data-en={edu.description}
						data-es={edu.descriptionES}>
						{edu.description}
					</p>
					</div>
				))
				}

			</div>
		</section>


		<section class="max-w-3xl mx-auto py-8 sm:py-10 border-t border-gray-200 dark:border-gray-700 parallax-section ade-in px-2 sm:px-0">

			<!-- 标题 -->
			<div class="max-w-2xl mb-6 sm:mb-8">
				<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white"
					data-en={translations.projects.title.en}
					data-es={translations.projects.title.es}>
					{translations.projects.title.en}
				</h2>

				<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mt-2 sm:mt-3"
					data-en={translations.projects.description.en}
					data-es={translations.projects.description.es}>
					{translations.projects.description.en}
				</p>
			</div>

			<!-- 项目卡片 -->
			<div class="grid grid-cols-2 gap-4">
				{
				featuredProjects.map((project) => (
					<a href={`/projects/${project.slug}`} 
					class="animated-border group relative block p-px rounded-xl bg-gray-50 dark:bg-gray-900/50 border border-gray-200 dark:border-gray-800 
							transition-all duration-300 hover:scale-105">

					<div class="relative h-20 flex items-center justify-center text-center overflow-hidden rounded-lg">

						<!-- 正常状态 -->
						<div class="flex items-center justify-center h-full transition-all duration-300 group-hover:scale-90 group-hover:opacity-0 px-4">
						<h3 class="text-sm sm:text-base font-bold text-gray-900 dark:text-white">
							<span class="locale-es">{project.name}</span>
							<span class="locale-en">{project.enName}</span>
						</h3>
						</div>

						<!-- hover 状态 -->
						<div class="absolute inset-0 flex items-center justify-center translate-y-4 opacity-0 
									group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
							<span class="text-xs sm:text-sm font-bold text-primary dark:text-white uppercase tracking-wider"
								data-en={translations.projects.viewProject.en}
								data-es={translations.projects.viewProject.es}>
								{translations.projects.viewProject.en}
							</span>
						</div>

					</div>
					</a>
				))
				}
			</div>

			<!-- View all -->
			<div class="mt-6 text-center">
				<a href="/projects"
					class="inline-block text-sm sm:text-base font-medium text-gray-900 dark:text-white hover:underline transition-all"
					data-en={translations.projects.viewAll.en}
					data-es={translations.projects.viewAll.es}>
					{translations.projects.viewAll.en}
				</a>
			</div>

		</section>


		<section class="max-w-3xl mx-auto py-8 sm:py-10 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">

			<!-- 标题 -->
			<div class="max-w-2xl mb-8 sm:mb-10">
				<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white"
					data-en={workTranslations.title.en}
					data-es={workTranslations.title.es}>
					{workTranslations.title.en}
				</h2>

				<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400 mt-2 sm:mt-3"
				data-en={workTranslations.description.en}
				data-es={workTranslations.description.es}>
				{workTranslations.description.en}
				</p>
			</div>

			<!-- Timeline -->
			<div class="space-y-8 sm:space-y-12">

				{
				work.map((item) => (
					<div class="relative pl-6 sm:pl-8 border-l-2 border-gray-200 dark:border-gray-700 group cursor-pointer hover:scale-105 transition-all">

					<!-- 圆点 -->
					<div class="absolute -left-2 top-0 w-4 h-4 rounded-full bg-gray-400 dark:bg-gray-500 group-hover:scale-125 transition-transform"></div>

					<!-- 标题 + 时间 -->
					<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2">
						<h3 class="text-lg sm:text-xl font-semibold text-gray-900 dark:text-white"
							data-en={item.title}
							data-es={item.titleES}>
							{item.title}
						</h3>

						<span class="text-xs sm:text-sm text-gray-500 dark:text-gray-400"
							data-en={item.year}
							data-es={item.yearES}>
							{item.year}
						</span>
					</div>

					<!-- 公司 -->
					<p class="text-sm sm:text-lg text-gray-600 dark:text-gray-400 font-medium mb-2"
						data-en={item.company}
						data-es={item.companyES}>
						{item.company}
					</p>

					<!-- 描述 -->
					<p class="text-sm sm:text-base text-gray-600 dark:text-gray-400"
						data-en={item.description}
						data-es={item.descriptionES}>
						{item.description}
					</p>

					</div>
				))
				}

			</div>
		</section>


		<section class="max-w-3xl mx-auto pt-8 sm:pt-10 pb-20 sm:pb-15 border-t border-gray-200 dark:border-gray-700 parallax-section fade-in px-2 sm:px-0">
			<h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-6 sm:mb-8" data-en={translations.tech.en} data-es={translations.tech.es}>{translations.tech.en}</h2>
			
			<div class="tech-ticker-container">
				<div class="tech-ticker-content">
					<!-- First set -->
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">MATLAB</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Python</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">OpAmp</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">SarADC</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Bandgap</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">PLL</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">DLL</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">German & English</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Cadence Virtuoso</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">VHDL</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Calibre(DRC/LVS/PEX)</p>
					</div>
					
					<!-- Second set for seamless looping -->
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">MATLAB</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
						<p class="text-sm font-medium text-gray-900 dark:text-white">Python</p>
					</div>
					<div class="cursor-pointer px-4 py-2 rounded-full bg-transparent border border-gray-300 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-800 transition-all hover:scale-105 whitespace-nowrap">
